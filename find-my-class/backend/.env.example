# Must match frontend/vite.config.js proxy target (default there is often 7000).
PORT=5000
MONGODB_URI=mongodb://localhost:27017/find-my-class
NODE_ENV=development

# Required for JWT auth
JWT_SECRET=your-secret-key-change-in-production

# Optional: comma-separated browser origins (defaults include localhost:5173–5174)
# CORS_ORIGIN=http://localhost:5174

# --- Optional: scripts/copyDatabase.js (npm run copy-db) ---
# SOURCE_URI=mongodb+srv://USER:PASSWORD@cluster-a.mongodb.net/SourceDbName?retryWrites=true&w=majority
# DEST_URI=mongodb+srv://USER:PASSWORD@cluster-b.mongodb.net/destDbName?retryWrites=true&w=majority
# DEST_URI must be ONLY the URI — not a mongorestore / mongodump shell command.
